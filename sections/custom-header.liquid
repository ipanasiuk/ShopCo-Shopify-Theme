<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<div class="header-wrapper header-wrapper--border-bottom">
<header class="site-header section-header {% if section.settings.header_menu != blank %} header--has-menu{% endif %}">
  <div class="container">
    <div class="site-header__container">
      <div class="site-header__left">
        {%- liquid                 
            render 'custom-nav-menu'          
        %}
        <div class="site-header__logo">
          <a href="{{ routes.root_url }}">            
            {{ settings.logo | image_url: width: 126 | image_tag }}
          </a>
        </div>
      </div>
      <div class="site-header__right">
        <div class="site-header__search-mobile">
          {%  render 'custom-header-search', input_id: 'Search-In-Modal-1' %}
        </div>
